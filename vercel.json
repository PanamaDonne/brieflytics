{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/report",
      "schedule": "0 8 */3 * *"
    },
    {
      "path": "/api/cron/trial-check",
      "schedule": "0 9 * * *"
    }
  ],
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/tracker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
