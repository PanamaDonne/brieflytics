# ─────────────────────────────────────────────
# Supabase (EU region — Frankfurt or Stockholm)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
# Default chat ID for internal alerts; each subscriber stores their own
TELEGRAM_DEFAULT_CHAT_ID=your-chat-id

# ─────────────────────────────────────────────
# Resend (Email)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=reports@yourdomain.com

# ─────────────────────────────────────────────
# Stripe (tips / supporter tier)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Secret for internal cron/report endpoint
CRON_SECRET=generate-a-random-secret-here

# ─────────────────────────────────────────────
# Geo (optional — IP geolocation for country/city)
# IPs are hashed immediately and never persisted.
# Use a provider like ipapi.co (free tier), or
# a local MaxMind GeoLite2 DB for full privacy.
# ─────────────────────────────────────────────
GEO_PROVIDER=ipapi        # ipapi | maxmind | none
MAXMIND_DB_PATH=/path/to/GeoLite2-City.mmdb
